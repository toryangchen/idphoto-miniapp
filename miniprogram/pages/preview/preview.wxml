<view class="page safe-bottom">
  <view class="content">
    <view class="selector" bindtap="chooseSize">
      <text class="selector-label">{{currentLabel}}</text>
      <text class="selector-arrow">⌄</text>
    </view>

    <view class="canvas-shell">
      <view class="canvas-frame">
        <view class="portrait-stage {{stageClass}}" style="background: {{previewColor}};">
          <view class="guide-vertical"></view>
          <view class="guide-horizontal guide-top"></view>
          <view class="guide-horizontal guide-bottom"></view>

          <image wx:if="{{imagePath}}" src="{{imagePath}}" class="photo" mode="aspectFit"></image>

          <view wx:else class="placeholder-copy">
            <text class="placeholder-text">可拖动缩放</text>
            <text class="placeholder-text">人物图层</text>
          </view>
        </view>
      </view>
    </view>

    <text class="tip">拖动或双指缩放调整人物位置</text>
  </view>

  <view wx:if="{{showBackgroundSheet}}" class="sheet">
    <view class="sheet-handle"></view>
    <text class="sheet-title">选择底色</text>
    <view class="color-row">
      <view
        class="color-chip"
        wx:for="{{backgroundOptions}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="selectColor"
      >
        <view
          class="color-dot {{selectedBackground === item.key ? 'active' : ''}}"
          style="background: {{item.dotColor}}; border-color: {{selectedBackground === item.key ? item.strokeColor : (item.key === 'white' ? '#D1D5DB' : item.strokeColor)}};"
        ></view>
        <text class="color-label {{selectedBackground === item.key ? 'selected' : ''}}">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="bottom-btn secondary" bindtap="toggleBackgroundSheet">
      <view class="btn-dot"></view>
      <text class="bottom-btn-text">底色</text>
    </button>
    <button class="bottom-btn muted" bindtap="resetAll">
      <text class="bottom-btn-text">重置</text>
    </button>
    <button class="bottom-btn primary" bindtap="savePhoto">
      <text class="bottom-btn-text">保存</text>
    </button>
  </view>
</view>
