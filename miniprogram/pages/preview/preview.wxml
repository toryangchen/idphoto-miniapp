<view class="page preview-page safe-bottom">
  <view class="status-pill">
    <image class="status-icon ruler-icon" src="/assets/preview-icons/ruler.svg" mode="aspectFit"></image>
    <text class="status-main">{{currentLabel}}</text>
    <view class="status-sep"></view>
    <text class="status-sub">{{currentSpec}}</text>
    <view class="status-sep"></view>
    <text class="status-bg">{{currentBgLabel}}</text>
  </view>

  <view class="canvas-wrap">
    <view class="portrait-stage {{stageClass}}" style="background: {{previewColor}};">
      <image src="{{imagePath}}" class="photo" mode="aspectFit"></image>
    </view>
  </view>

  <text class="tip">拖动移动人物 · 双指缩放</text>

  <view class="sheet">
    <view class="sheet-block">
      <view class="sheet-title-row">
        <image class="status-icon ruler-icon small" src="/assets/preview-icons/ruler.svg" mode="aspectFit"></image>
        <text class="sheet-title">选择规格</text>
      </view>

      <view class="sheet-size-row">
        <view
          class="sheet-size-chip {{selectedSize === item.key ? 'active' : ''}}"
          wx:for="{{sizeOptions}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="selectSize"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="sheet-block color-block">
      <view class="sheet-title-row">
        <image class="status-icon palette-icon" src="/assets/preview-icons/palette.svg" mode="aspectFit"></image>
        <text class="sheet-title">选择底色</text>
      </view>

      <view class="sheet-color-row">
        <view
          class="sheet-color-chip"
          wx:for="{{backgroundOptions}}"
          wx:key="key"
          data-key="{{item.key}}"
          bindtap="selectColor"
        >
          <view class="sheet-color-outer {{selectedBackground === item.key ? 'active' : ''}}" style="border-color: {{selectedBackground === item.key ? item.strokeColor : 'transparent'}};">
            <view class="sheet-color-dot" style="background: {{item.dotColor}}; border-color: {{item.key === 'white' ? '#D1D5DB' : item.strokeColor}};">
              <text wx:if="{{selectedBackground === item.key}}" class="color-check {{item.key === 'white' ? 'dark' : ''}}">✓</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="action-btn action-btn-muted auto-btn" bindtap="autoCenter">
      <text class="action-btn-text muted-text">自动居中</text>
    </view>
    <view class="action-btn action-btn-muted reset-btn" bindtap="resetAll">
      <text class="action-btn-text muted-text">重置</text>
    </view>
    <view class="action-btn action-btn-primary save-btn" bindtap="savePhoto">
      <text class="action-btn-text primary-text">保存</text>
    </view>
  </view>
</view>
